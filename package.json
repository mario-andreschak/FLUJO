{
  "name": "flujo-ai",
  "version": "3.9.1",
  "bin": {
    "flujo": "bin/flujo.mjs"
  },
  "files": [
    ".next/**/*",
    "!.next/cache/**",
    "public/**/*",
    "scripts/launch-next.mjs",
    "bin/**/*",
    "next.config.mjs"
  ],
  "scripts": {
    "dev": "node scripts/launch-next.mjs dev -p 4200",
    "turbo": "node scripts/launch-next.mjs dev --turbopack -p 4200",
    "build": "next build",
    "start": "node scripts/launch-next.mjs start -p 4200",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "prepublishOnly": "npm run build",
    "version": "node scripts/sync-version.mjs && git add -A src README.md githubpages/index.html",
    "release": "npm version minor -m \"Bump version to %s\" && npm publish"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.186",
    "@anthropic-ai/sdk": "^0.105.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@google/genai": "^2.9.0",
    "@isomorphic-git/lightning-fs": "^4.6.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mui/icons-material": "^6.4.5",
    "@mui/material": "^6.4.5",
    "@uiw/react-md-editor": "^4.0.5",
    "@xyflow/react": "^12.4.4",
    "axios": "^1.8.4",
    "chokidar": "^4.0.3",
    "croner": "^10.0.1",
    "crypto-js": "^4.2.0",
    "fetch-to-node": "^2.1.0",
    "isomorphic-git": "^1.29.0",
    "jszip": "^3.10.1",
    "lodash": "^4.17.21",
    "mcp-remote": "^0.1.18",
    "next": "^15.5.20",
    "node-fetch": "^3.3.2",
    "openai": "^4.86.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "simple-git": "^3.36.0",
    "slate": "^0.112.0",
    "slate-history": "^0.110.3",
    "slate-react": "^0.112.1",
    "uuid": "^11.1.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "zod": "$zod"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/crypto-js": "^4.2.2",
    "@types/jest": "^29.5.14",
    "@types/lodash": "^4.17.16",
    "@types/node": "20.17.30",
    "@types/react": "19.1.0",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/parser": "^8.26.1",
    "buffer": "^6.0.3",
    "eslint": "^9",
    "eslint-config-next": "15.1.7",
    "eslint-import-resolver-typescript": "^3.8.4",
    "eslint-plugin-import": "^2.31.0",
    "jest": "^29.7.0",
    "node-loader": "^2.1.0",
    "postcss": "^8",
    "postcss-flexbugs-fixes": "^5.0.2",
    "postcss-preset-env": "^10.1.5",
    "process": "^0.11.10",
    "typescript": "5.8.3",
    "wait-on": "^8.0.2",
    "webpack": "^5.98.0"
  }
}
